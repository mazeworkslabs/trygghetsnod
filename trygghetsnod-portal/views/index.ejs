<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= config.kommun %> – Trygghetspunkt <%= config.plats %></title>
<link rel="stylesheet" href="/style.css" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
<meta name="theme-color" content="#1E3A5F" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-title" content="Trygghetsnod" />
<script>if('serviceWorker' in navigator){navigator.serviceWorker.register('/sw.js').catch(function(){})}</script>
</head>
<body>
<%- include('_header', { title: 'Trygghetsnod', subtitle: config.kommun + ' · ' + config.plats }) %>

<main>
  <section class="update sev-<%= update.severity %>">
    <div class="sev-label"><%= sev.label %></div>
    <h1><%= update.title %></h1>
    <div class="update-body"><%= update.body %></div>
    <div class="update-meta">
      Uppdaterat <%= formatDate(update.updated_at) %> · <%= update.author %>
    </div>
  </section>

  <% if (typeof articles !== 'undefined' && articles.length > 0) { %>
    <section class="panel">
      <div class="news-section-head">
        <h2>Senaste från kommunen</h2>
        <% if (articles.length > 3) { %>
          <a href="/nyheter" class="news-section-all">Alla nyheter →</a>
        <% } %>
      </div>
      <ul class="news-list">
        <% articles.slice(0, 3).forEach(a => { %>
          <li>
            <a class="news-card" href="/nyheter/<%= a.slug %>">
              <% if (a.image) { %>
                <div class="news-thumb"><img src="<%= a.image %>" alt="" loading="lazy" /></div>
              <% } %>
              <div class="news-body">
                <div class="news-meta"><%= a.date %> · <%= a.author %></div>
                <h3 class="news-title"><%= a.title %></h3>
                <% if (a.summary) { %>
                  <p class="news-summary"><%= a.summary %></p>
                <% } %>
              </div>
            </a>
          </li>
        <% }) %>
      </ul>
    </section>
  <% } %>

  <section class="panel">
    <h2>Information och verktyg</h2>
    <div class="cards">
      <a class="card" href="/sok">
        <h3>Sök</h3>
        <p>Hitta information i allt lokalt innehåll.</p>
      </a>
      <a class="card" href="/forum">
        <h3>Forum</h3>
        <p>Skriv till andra i kommunen. FRG modererar.</p>
      </a>
      <a class="card" href="/kartor">
        <h3>Kartor</h3>
        <p>Offline-karta med <%= config.kommun %>s trygghetspunkter.</p>
      </a>
      <% (books || []).filter(b => b.language === 'swe').forEach(b => { %>
        <a class="card" href="/innehall/<%= b.slug %>/">
          <h3><%= b.title %></h3>
          <p><%= b.summary || 'Offline-bibliotek.' %></p>
        </a>
      <% }) %>
    </div>
  </section>

</main>

<footer class="site">
  <div>Trygghetsnod · <%= config.kommun %></div>
  <div>Vid akut fara: ring 112</div>
</footer>
</body>
</html>
