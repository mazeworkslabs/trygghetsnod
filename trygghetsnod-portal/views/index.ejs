<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= config.kommun %> – Trygghetspunkt <%= config.plats %></title>
<link rel="stylesheet" href="/style.css" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
<meta name="theme-color" content="#1E3A5F" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-title" content="Trygghetsnod" />
<script>if('serviceWorker' in navigator){navigator.serviceWorker.register('/sw.js').catch(function(){})}</script>
</head>
<body>
<header class="site">
  <div class="brand">
    <div class="brand-name">Trygghetsnod</div>
    <div class="brand-sub"><%= config.kommun %> · <%= config.plats %></div>
  </div>
</header>

<main>
  <section class="update sev-<%= update.severity %>">
    <div class="sev-label"><%= sev.label %></div>
    <h1><%= update.title %></h1>
    <div class="update-body"><%= update.body %></div>
    <div class="update-meta">
      Uppdaterat <%= formatDate(update.updated_at) %> · <%= update.author %>
    </div>
  </section>

  <section class="panel">
    <h2>Information och verktyg</h2>
    <div class="cards">
      <a class="card" href="/sok">
        <h3>Sök</h3>
        <p>Hitta information i allt lokalt innehåll.</p>
      </a>
      <% if (typeof articles !== 'undefined' && articles.length > 0) { %>
        <a class="card" href="/nyheter">
          <h3>Nyheter</h3>
          <p><%= articles.length %> <%= articles.length === 1 ? 'publicerad artikel' : 'publicerade artiklar' %> från kommunen.</p>
        </a>
      <% } %>
      <a class="card" href="/forum">
        <h3>Forum</h3>
        <p>Skriv till andra som är här. FRG-volontärer modererar.</p>
      </a>
      <a class="card" href="/kartor">
        <h3>Kartor</h3>
        <p>Offline-karta med <%= config.kommun %>s trygghetspunkter.</p>
      </a>
      <% (books || []).filter(b => b.language === 'swe').forEach(b => { %>
        <a class="card" href="/innehall/<%= b.slug %>/">
          <h3><%= b.title %></h3>
          <p><%= b.summary || 'Offline-bibliotek.' %></p>
        </a>
      <% }) %>
    </div>
  </section>

  <section class="panel panel-compact">
    <div>Ingen internet? Det är normalt här. All information nedan är lokal.</div>
    <div><a href="/print">Skriv ut aktuell lägesuppdatering (A4)</a></div>
  </section>
</main>

<footer class="site">
  <div>Trygghetsnod · <%= config.kommun %></div>
  <div>Vid akut fara: ring 112</div>
</footer>
</body>
</html>
