<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Nyheter – <%= config.kommun %></title>
<link rel="stylesheet" href="/style.css" />
</head>
<body>
<%- include('_header', { back: '/', title: 'Nyheter', subtitle: 'Trygghetsnod · ' + config.kommun }) %>

<main>
  <section class="panel">
    <h2>Nyheter från kommunen</h2>
    <% if (articles.length === 0) { %>
      <p>Inga nyheter publicerade ännu.</p>
    <% } else { %>
      <ul class="news-list">
        <% articles.forEach(a => { %>
          <li>
            <a class="news-card" href="/nyheter/<%= a.slug %>">
              <% if (a.image) { %>
                <div class="news-thumb"><img src="<%= a.image %>" alt="" loading="lazy" /></div>
              <% } %>
              <div class="news-body">
                <div class="news-meta"><%= a.date %> · <%= a.author %></div>
                <h3 class="news-title"><%= a.title %></h3>
                <% if (a.summary) { %>
                  <p class="news-summary"><%= a.summary %></p>
                <% } %>
              </div>
            </a>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>
</main>

<footer class="site">
  <div>Trygghetsnod · <%= config.kommun %></div>
  <div>Vid akut fara: ring 112</div>
</footer>
</body>
</html>
