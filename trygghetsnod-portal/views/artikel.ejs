<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= article.title %> – <%= config.kommun %></title>
<link rel="stylesheet" href="/style.css" />
</head>
<body>
<%- include('_header', { back: '/nyheter', title: 'Nyhet', subtitle: 'Trygghetsnod · ' + config.kommun }) %>

<main>
  <article class="panel article">
    <% if (article.image) { %>
      <div class="article-hero"><img src="<%= article.image %>" alt="" /></div>
    <% } %>
    <div class="article-meta"><%= article.date %> · <%= article.author %></div>
    <h1><%= article.title %></h1>
    <% if (article.summary) { %>
      <p class="article-summary"><%= article.summary %></p>
    <% } %>
    <div class="article-body"><%- html %></div>
  </article>
</main>

<footer class="site">
  <div>Trygghetsnod · <%= config.kommun %></div>
  <div>Vid akut fara: ring 112</div>
</footer>
<script>
  // Om sidan öppnats med ?print=1 (från admin "Skriv ut"-knappen) — auto-trigga
  // utskriftsdialogen så användaren slipper själv klicka Cmd+P.
  if (location.search.includes('print=1')) {
    addEventListener('load', function () { setTimeout(function () { window.print() }, 300) })
  }
</script>
</body>
</html>
