<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= article.title %> – <%= config.kommun %></title>
<link rel="stylesheet" href="/style.css" />
</head>
<body>
<header class="site">
  <div class="brand">
    <div class="brand-name">Trygghetsnod</div>
    <div class="brand-sub"><%= config.kommun %> · <%= config.plats %></div>
  </div>
  <nav><a href="/nyheter">Alla nyheter</a> · <a href="/">Portalen</a></nav>
</header>

<main>
  <article class="panel article">
    <div class="article-meta"><%= article.date %> · <%= article.author %></div>
    <h1><%= article.title %></h1>
    <% if (article.summary) { %>
      <p class="article-summary"><%= article.summary %></p>
    <% } %>
    <div class="article-body"><%- html %></div>
  </article>
</main>

<footer class="site">
  <div>Trygghetsnod · <%= config.kommun %></div>
  <div>Vid akut fara: ring 112</div>
</footer>
</body>
</html>
