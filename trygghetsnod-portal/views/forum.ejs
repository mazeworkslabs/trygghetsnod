<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Forum – <%= config.kommun %></title>
<link rel="stylesheet" href="/style.css" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
<meta name="theme-color" content="#1E3A5F" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="Trygghetsnod" />
<script>if('serviceWorker' in navigator){navigator.serviceWorker.register('/sw.js').catch(function(){})}</script>
</head>
<body>
<%- include('_header', { back: '/', title: 'Forum', subtitle: config.kommun }) %>

<main class="wall-main">
  <% if (mode === 'verifierade') { %>
    <div class="wall-gate">
      <strong>Skrivläge: endast verifierade.</strong>
      Du kan läsa allt fritt. För att posta inlägg behöver du en token från FRG-volontärerna.
    </div>
  <% } %>

  <% if (groups.length === 0) { %>
    <p>Inga grupper finns än.</p>
  <% } else { %>
    <ul class="group-list">
      <% groups.forEach(g => { %>
        <li>
          <a class="group-card" href="/forum/<%= g.slug %>">
            <div class="group-card-body">
              <h3 class="group-card-name"><%= g.name %></h3>
              <% if (g.description) { %>
                <p class="group-card-desc"><%= g.description %></p>
              <% } %>
              <div class="group-card-meta">
                <%= g.message_count %> inlägg<% if (g.last_message_at) { %> · senast <%= formatDate(g.last_message_at) %><% } %>
              </div>
            </div>
            <svg class="group-card-arrow" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </li>
      <% }) %>
    </ul>
  <% } %>
</main>

<footer class="site">
  <div>Trygghetsnod · <%= config.kommun %></div>
  <div>Vid akut fara: ring 112</div>
</footer>
</body>
</html>
