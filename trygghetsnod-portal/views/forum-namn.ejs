<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Byt namn – Forum – <%= config.kommun %></title>
<link rel="stylesheet" href="/style.css" />
</head>
<body>
<header class="site">
  <div class="brand">
    <div class="brand-name">Trygghetsnod</div>
    <div class="brand-sub"><%= config.kommun %> · <%= config.plats %></div>
  </div>
  <nav><a href="/forum">Tillbaka till forum</a></nav>
</header>

<main>
  <section class="panel">
    <h2>Byt visningsnamn</h2>
    <p class="panel-lead">Namnet syns intill dina meddelanden. Ändringen gäller framåt. Gamla meddelanden behåller det namn du hade då.</p>

    <form class="forum-name-form" action="/forum/namn" method="post">
      <label for="name">Nytt visningsnamn</label>
      <input id="name" name="name" type="text" required maxlength="60" value="<%= current %>" />
      <input type="hidden" name="redirect" value="<%= redirect %>" />
      <button type="submit">Spara</button>
    </form>
  </section>
</main>

<footer class="site">
  <div>Trygghetsnod · <%= config.kommun %></div>
  <div>Vid akut fara: ring 112</div>
</footer>
</body>
</html>
