<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= post.author_name %> – <%= group.name %></title>
<link rel="stylesheet" href="/style.css" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
<meta name="theme-color" content="#1E3A5F" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="Trygghetsnod" />
<script>if('serviceWorker' in navigator){navigator.serviceWorker.register('/sw.js').catch(function(){})}</script>
</head>
<body data-name="<%= displayName %>" data-group-id="<%= group.id %>" data-post-id="<%= post.id %>" data-can-post="<%= ((mode !== 'verifierade') || identity.verified) && displayName ? '1' : '0' %>" data-role="<%= identity.role %>" data-verified="<%= identity.verified ? '1' : '0' %>">
<%- include('_header', { back: '/forum/' + group.slug, title: 'Inlägg', subtitle: group.name }) %>

<main class="wall-main">
  <ul id="posts" class="wall-posts" data-single="1"></ul>
</main>

<footer class="site">
  <div>Trygghetsnod · <%= config.kommun %></div>
  <div>Vid akut fara: ring 112</div>
</footer>

<script>
(function () {
  var groupId = document.body.dataset.groupId;
  var postId = document.body.dataset.postId;
  var myName = document.body.dataset.name || '';
  var canPost = document.body.dataset.canPost === '1';
  var listEl = document.getElementById('posts');
  if (!listEl) return;

  var LIKE_EMOJI = '❤';

  var ICON_HEART_OUTLINE =
    '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">' +
    '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  var ICON_HEART_FILLED =
    '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">' +
    '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="currentColor"/></svg>';
  var ICON_COMMENT =
    '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">' +
    '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  var ICON_SEND =
    '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">' +
    '<path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>';

  function escapeHTML(s) {
    return String(s).replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  function fmtTime(iso) {
    try {
      var d = new Date(iso);
      var now = new Date();
      var diffMs = now - d;
      var diffMin = Math.floor(diffMs / 60000);
      if (diffMin < 1) return 'just nu';
      if (diffMin < 60) return diffMin + ' min sedan';
      var p = function (n) { return String(n).padStart(2, '0'); };
      var same = d.toDateString() === now.toDateString();
      var time = p(d.getHours()) + ':' + p(d.getMinutes());
      if (same) return 'idag ' + time;
      var sameYear = d.getFullYear() === now.getFullYear();
      var date = p(d.getDate()) + '/' + p(d.getMonth() + 1);
      if (sameYear) return date + ' ' + time;
      return d.getFullYear() + '-' + p(d.getMonth() + 1) + '-' + p(d.getDate());
    } catch (e) { return ''; }
  }

  function renderBody(raw) {
    var esc = escapeHTML(raw);
    esc = esc.replace(/(^|\s)(@[\wÅÄÖåäöÉéÈèÀàÇç][\wÅÄÖåäöÉéÈèÀàÇç._-]{0,30})/g,
      function (_, pre, mention) { return pre + '<span class="forum-mention">' + mention + '</span>'; });
    return esc.replace(/\n/g, '<br />');
  }

  var AVATAR_COLORS = ['#2b5b8a','#a8571a','#5b6b3a','#7a3b6a','#3b6b6a','#8a4a2b','#4a4a8a','#6b3b3b','#3b6b4a','#8a6b2b'];
  function avatarHash(name) {
    var s = String(name || '?'); var h = 0;
    for (var i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
    return Math.abs(h);
  }
  function avatarInitials(name) {
    var parts = String(name || '?').replace(/[^\p{L}\s]/gu, ' ').trim().split(/\s+/).filter(Boolean);
    if (parts.length === 0) return '?';
    if (parts.length === 1) return parts[0].slice(0, 1).toUpperCase();
    return (parts[0].slice(0, 1) + parts[parts.length - 1].slice(0, 1)).toUpperCase();
  }
  function renderAvatar(name, isFrg, size) {
    var color = isFrg ? '#1E3A5F' : AVATAR_COLORS[avatarHash(name) % AVATAR_COLORS.length];
    var initials = avatarInitials(name);
    var shield = isFrg ? '<span class="frg-shield" aria-hidden="true">&#10003;</span>' : '';
    var cls = 'wall-avatar' + (size === 'sm' ? ' wall-avatar-sm' : '');
    return '<div class="' + cls + '" style="background:' + color + '" aria-hidden="true">' + escapeHTML(initials) + shield + '</div>';
  }

  function badges(role, verified) {
    if (verified && role !== 'frg') {
      return '<span class="forum-verified" title="Verifierad hos FRG">&#10003;</span>';
    }
    return '';
  }

  function actionRow(post) {
    var hearts = (post.reactions || []).find(function (r) { return r.emoji === LIKE_EMOJI; });
    var users = hearts ? hearts.users : [];
    var likeCount = hearts ? hearts.count : 0;
    var mineActive = myName && users.indexOf(myName) !== -1;
    var likeIcon = mineActive ? ICON_HEART_FILLED : ICON_HEART_OUTLINE;
    return '<div class="wall-actions">' +
      '<button type="button" class="wall-icon-btn wall-like' + (mineActive ? ' is-active' : '') + '"' +
        ' data-id="' + post.id + '"' +
        (canPost ? '' : ' disabled') + '>' + likeIcon +
        (likeCount > 0 ? '<span class="wall-icon-count">' + likeCount + '</span>' : '') +
      '</button>' +
    '</div>';
  }

  function replyLikeRow(reply) {
    var hearts = (reply.reactions || []).find(function (r) { return r.emoji === LIKE_EMOJI; });
    var users = hearts ? hearts.users : [];
    var count = hearts ? hearts.count : 0;
    var mineActive = myName && users.indexOf(myName) !== -1;
    var likeWord = '<span class="wall-reply-like-text' + (mineActive ? ' is-active' : '') + '"' +
      ' data-id="' + reply.id + '"' +
      (canPost ? '' : ' aria-disabled="true"') + '>Gilla</span>';
    var countSpan = count > 0
      ? '<span class="wall-reply-like-count" title="' + escapeHTML(users.join(', ')) + '">❤ ' + count + '</span>'
      : '';
    return '<span class="wall-reply-actions">' + likeWord + countSpan + '</span>';
  }

  function renderReply(reply) {
    var isFrg = reply.author_role === 'frg';
    var verifiedBadge = badges(reply.author_role, reply.verified);
    var body = reply.deleted_at
      ? '<em class="wall-reply-removed">Borttaget av ' + escapeHTML(reply.moderated_by || 'FRG') + '</em>'
      : renderBody(reply.body);
    var image = reply.image_path
      ? '<div class="wall-reply-image"><img src="' + escapeHTML(reply.image_path) + '" alt="" loading="lazy" /></div>'
      : '';
    return '<div class="wall-inline-reply">' +
      renderAvatar(reply.author_name, isFrg, 'sm') +
      '<div class="wall-inline-reply-text">' +
        '<span class="wall-inline-reply-author">' + escapeHTML(reply.author_name) + '</span>' + verifiedBadge + ' ' +
        '<span class="wall-inline-reply-body">' + body + '</span>' +
        image +
        '<div class="wall-inline-reply-meta">' +
          '<span class="wall-inline-reply-time">' + escapeHTML(fmtTime(reply.created_at)) + '</span>' +
          (reply.deleted_at ? '' : ' · ' + replyLikeRow(reply)) +
        '</div>' +
      '</div>' +
    '</div>';
  }

  function commentInputHTML() {
    if (!canPost) return '';
    return '<form class="wall-reply-form" data-id="' + postId + '">' +
      '<input type="text" class="wall-reply-input" maxlength="1000" placeholder="Kommentera som ' + escapeHTML(myName) + '…" required />' +
      '<button type="submit" class="wall-icon-btn" aria-label="Skicka">' + ICON_SEND + '</button>' +
    '</form>';
  }

  function renderPost(post, replies) {
    var li = document.createElement('li');
    var isFrg = post.author_role === 'frg';
    li.className = 'wall-post wall-post-detail' + (isFrg ? ' wall-post-frg' : '');
    li.id = 'p-' + post.id;
    var rolePrefix = isFrg ? '<span class="wall-role-tag">FRG</span> · ' : '';
    var head = '<div class="wall-post-head">' +
      renderAvatar(post.author_name, isFrg) +
      '<div class="wall-post-byline">' +
        '<div class="wall-post-author">' + escapeHTML(post.author_name) + badges(post.author_role, post.verified) + '</div>' +
        '<div class="wall-post-time">' + rolePrefix + escapeHTML(fmtTime(post.created_at)) + '</div>' +
      '</div>' +
    '</div>';
    var body = post.deleted_at
      ? '<div class="wall-post-body wall-post-removed">Borttaget av ' + escapeHTML(post.moderated_by || 'FRG') + '</div>'
      : (post.body ? '<div class="wall-post-body">' + renderBody(post.body) + '</div>' : '');
    var image = (!post.deleted_at && post.image_path)
      ? '<div class="wall-post-image"><img src="' + escapeHTML(post.image_path) + '" alt="" /></div>'
      : '';
    var actions = post.deleted_at ? '' : actionRow(post);
    var threadList = '<div class="wall-thread-list">' + replies.map(renderReply).join('') + '</div>';
    var input = post.deleted_at ? '' : commentInputHTML();
    li.innerHTML = head + body + image + actions + threadList + input;
    return li;
  }

  function load() {
    // Skippa uppdatering om användaren just nu skriver i kommentar-fältet —
    // annars försvinner deras utkast varje 5:e sekund.
    var existingInput = listEl.querySelector('.wall-reply-input');
    if (existingInput && document.activeElement === existingInput && existingInput.value) {
      return;
    }
    // Annars: bevara utkast och eventuellt fokus över re-render.
    var draft = existingInput ? existingInput.value : '';
    var hadFocus = existingInput && document.activeElement === existingInput;
    var selStart = hadFocus ? existingInput.selectionStart : null;
    var selEnd = hadFocus ? existingInput.selectionEnd : null;

    Promise.all([
      fetch('/api/forum/posts/' + postId).then(function (r) { return r.json(); }),
      fetch('/api/forum/posts/' + postId + '/replies').then(function (r) { return r.json(); }),
    ]).then(function (results) {
      var post = results[0].post;
      var replies = results[1].replies || [];
      if (!post) {
        listEl.innerHTML = '<li class="wall-empty">Inlägget hittades inte.</li>';
        return;
      }
      listEl.innerHTML = '';
      listEl.appendChild(renderPost(post, replies));
      if (draft) {
        var newInp = listEl.querySelector('.wall-reply-input');
        if (newInp) {
          newInp.value = draft;
          if (hadFocus) {
            newInp.focus();
            if (selStart !== null && selEnd !== null) {
              try { newInp.setSelectionRange(selStart, selEnd); } catch (e) {}
            }
          }
        }
      }
    }).catch(function () {});
  }

  // Like på post
  listEl.addEventListener('click', function (e) {
    var likeBtn = e.target.closest('.wall-like');
    if (likeBtn && !likeBtn.disabled) {
      var id = likeBtn.dataset.id;
      likeBtn.classList.toggle('is-active');
      likeBtn.innerHTML = likeBtn.classList.contains('is-active') ? ICON_HEART_FILLED : ICON_HEART_OUTLINE;
      fetch('/api/forum/messages/' + id + '/reactions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ emoji: LIKE_EMOJI })
      }).then(function () { load(); }).catch(function () {});
      return;
    }
    var replyLike = e.target.closest('.wall-reply-like-text');
    if (replyLike && replyLike.getAttribute('aria-disabled') !== 'true') {
      var rid = replyLike.dataset.id;
      replyLike.classList.toggle('is-active');
      fetch('/api/forum/messages/' + rid + '/reactions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ emoji: LIKE_EMOJI })
      }).then(function () { load(); }).catch(function () {});
      return;
    }
  });

  // Skicka kommentar
  listEl.addEventListener('submit', function (e) {
    var form = e.target.closest('.wall-reply-form');
    if (!form) return;
    e.preventDefault();
    var input = form.querySelector('.wall-reply-input');
    var text = input.value.trim();
    if (!text) return;
    fetch('/api/forum/groups/' + groupId + '/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ body: text, parent_id: Number(postId) })
    }).then(function (r) {
      if (!r.ok) return r.json().then(function (d) { throw new Error(d.error || 'Kunde inte posta'); });
      input.value = '';
      load();
    }).catch(function (err) { alert(err.message); });
  });

  load();
  setInterval(load, 5000);
})();
</script>
</body>
</html>
