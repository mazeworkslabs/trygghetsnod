<%
// Generisk header för Trygghetsnod-portalen.
//
// Parametrar (alla optional):
//   back        — URL till parent-sida (visar back-pil om satt, annars logga)
//   title       — sidans titel (default 'Trygghetsnod')
//   subtitle    — text under titeln (default kommun · plats)
//
// Globalt från middleware:
//   viewerName, viewerVerified, viewerRole
//
// Avatar-färgen är deterministisk på namn så samma användare alltid får samma färg.
const _ = locals
const _back = _.back || null
const _title = _.title || 'Trygghetsnod'
const _subtitle = (typeof _.subtitle !== 'undefined') ? _.subtitle :
  (typeof config !== 'undefined' ? `${config.kommun} · ${config.plats}` : '')
const _name = _.viewerName || ''
const _verified = !!_.viewerVerified
const _role = _.viewerRole || 'medborgare'

const AVATAR_COLORS = [
  '#2b5b8a', '#a8571a', '#5b6b3a', '#7a3b6a', '#3b6b6a',
  '#8a4a2b', '#4a4a8a', '#6b3b3b', '#3b6b4a', '#8a6b2b',
]
function avatarHash(s) { let h = 0; for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0; return Math.abs(h) }
function avatarInitials(s) {
  const parts = String(s || '').replace(/[^\p{L}\s]/gu, ' ').trim().split(/\s+/).filter(Boolean)
  if (parts.length === 0) return ''
  if (parts.length === 1) return parts[0].slice(0, 1).toUpperCase()
  return (parts[0].slice(0, 1) + parts[parts.length - 1].slice(0, 1)).toUpperCase()
}
const _avatarColor = _role === 'frg' ? '#1E3A5F' : (_name ? AVATAR_COLORS[avatarHash(_name) % AVATAR_COLORS.length] : '#bbb')
const _avatarInitials = avatarInitials(_name)
%>
<header class="app-header">
  <div class="app-header-left">
    <% if (_back) { %>
      <a href="<%= _back %>" class="app-header-icon-btn" aria-label="Tillbaka">
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path d="M15 6l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    <% } else { %>
      <a href="/" class="app-header-logo" aria-label="Hem">
        <svg width="28" height="28" viewBox="0 0 22 22" aria-hidden="true">
          <rect x="2" y="9" width="18" height="11" stroke="#1E3A5F" stroke-width="1.4" fill="#EDF1F6"/>
          <path d="M2 9L11 2L20 9" stroke="#1E3A5F" stroke-width="1.4" fill="#EDF1F6" stroke-linejoin="round"/>
          <rect x="9" y="13" width="4" height="7" stroke="#1E3A5F" stroke-width="1.4" fill="#FDFDFC"/>
        </svg>
      </a>
    <% } %>
  </div>

  <div class="app-header-title">
    <h1><%= _title %></h1>
    <% if (_subtitle) { %><p><%= _subtitle %></p><% } %>
  </div>

  <div class="app-header-right">
    <a href="/profil" class="app-header-profile<%= _.viewerAvatar ? ' has-image' : '' %>" aria-label="<%= _name ? 'Profil: ' + _name : 'Sätt visningsnamn' %>">
      <% if (_.viewerAvatar) { %>
        <img src="<%= _.viewerAvatar %>" alt="" />
      <% } else { %>
        <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
          <circle cx="12" cy="8" r="4" fill="none" stroke="currentColor" stroke-width="1.8"/>
          <path d="M4 21c0-4 4-7 8-7s8 3 8 7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      <% } %>
      <% if (_verified || _role === 'frg') { %>
        <span class="app-header-profile-shield" aria-hidden="true">&#10003;</span>
      <% } %>
    </a>
  </div>
</header>
