# Trygghetsnod — miljövariabler
# Alla har sane defaults. Sätt bara det som ska avvika.

# Vilken kommun-mapp portalen ska läsa från (kommuner/<kommun>/)
KOMMUN=arvika

# Portalens lyssningsport (default 8400)
# PORT=8400

# Bas-URL till Kiwix-servern (default http://localhost:8090)
# Behöver bara sättas om Kiwix flyttas (ex. annan host eller port)
# KIWIX_BASE=http://localhost:8090
